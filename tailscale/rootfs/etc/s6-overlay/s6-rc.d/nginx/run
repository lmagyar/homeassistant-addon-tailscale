#!/command/with-contenv bashio
# shellcheck shell=bash
export LOG_FD
# ==============================================================================
# Home Assistant Community App: Tailscale
# Runs the Nginx daemon
# ==============================================================================

# Add timestamp to plain stdout and stderr messages
exec &> >(ts "${__BASHIO_LOG_TIMESTAMP} service $(basename ${PWD}):")

# Wait for the Tailscale webinterface to become available
bashio::net.wait_for 25898 localhost 900

bashio::log.info "Starting NGinx..."
exec nginx
